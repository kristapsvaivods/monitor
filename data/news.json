<!DOCTYPE html>
<html lang="lv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kalve Coffee Monitor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap');
        .header-font { font-family: 'Playfair Display', sans-serif; }
        .coffee-bg { background: linear-gradient(135deg, #8d5524 0%, #5c3317 100%); }
    </style>
</head>
<body class="bg-neutral-950 text-neutral-200">
    <div class="coffee-bg text-white py-6">
        <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-4xl">☕</div>
                <div>
                    <h1 class="header-font text-4xl">Kalve Coffee Monitor</h1>
                    <p class="opacity-75">Auto-updated from Latvian media + Stock</p>
                </div>
            </div>
            <div class="text-sm">
                Last updated: <span id="last-updated" class="font-mono"></span>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-10">
        <!-- Stock Chart -->
        <div class="mb-12 bg-neutral-900 rounded-3xl p-6">
            <h2 class="text-xl font-semibold mb-4">KALVE Akcija (Nasdaq Riga)</h2>
            <div class="rounded-2xl overflow-hidden border border-neutral-700">
                <iframe src="https://www.tradingview.com/widgetembed/?symbol=OMXRSE%3AKALVE&interval=D&theme=dark&style=1&hide_side_toolbar=0&hide_top_toolbar=0&hide_legend=1&width=100%&height=420" 
                        width="100%" height="420" frameborder="0" allowfullscreen></iframe>
            </div>
        </div>

        <!-- Latvian News -->
        <h2 class="text-2xl font-semibold mb-6 flex items-center gap-3">
            <i class="fa-solid fa-newspaper text-amber-300"></i> 
            Jaunākās ziņas no Latvijas portāliem
        </h2>
        <div id="news-container" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
    </div>

    <script>
        async function loadNews() {
            try {
                const res = await fetch('data/news.json');
                const data = await res.json();
                
                document.getElementById('last-updated').textContent = data.lastUpdated || 'Just now';

                const container = document.getElementById('news-container');
                container.innerHTML = data.articles.map(article => `
                    <a href="${article.link}" target="_blank" class="block bg-neutral-900 rounded-3xl p-6 hover:bg-neutral-800 transition-colors">
                        <div class="flex justify-between text-xs mb-3">
                            <span class="text-amber-300">${article.source}</span>
                            <span class="text-neutral-500">${article.time}</span>
                        </div>
                        <h3 class="font-semibold leading-tight">${article.title}</h3>
                        ${article.summary ? `<p class="text-sm text-neutral-400 mt-3 line-clamp-3">${article.summary}</p>` : ''}
                    </a>
                `).join('');
            } catch(e) {
                console.log("No news.json yet — first scrape pending");
            }
        }

        window.onload = loadNews;
    </script>
</body>
</html>
